exports[`Calendar > renders a single-mode calendar (snapshot) 1`] = `
<div
  class="rdp-root p-3 pointer-events-auto"
  data-mode="single"
  lang="en-US"
>
  <div
    class="flex flex-col sm:flex-row space-y-4 sm:space-x-4 sm:space-y-0"
  >
    <nav
      aria-label="Navigation bar"
      class="space-x-1 flex items-center"
    >
      <button
        aria-label="Go to the Previous Month"
        class="rdp-button_previous"
        type="button"
      >
        <svg
          class="rdp-chevron"
          height="24"
          viewBox="0 0 24 24"
          width="24"
        >
          <polygon
            points="16 18.112 9.81111111 12 16 5.87733333 14.0888889 4 6 12 14.0888889 20"
          />
        </svg>
      </button>
      <button
        aria-label="Go to the Next Month"
        class="rdp-button_next"
        type="button"
      >
        <svg
          class="rdp-chevron"
          height="24"
          viewBox="0 0 24 24"
          width="24"
        >
          <polygon
            points="8 18.112 14.18888889 12 8 5.87733333 9.91111111 4 18 12 9.91111111 20"
          />
        </svg>
      </button>
